# ============================================================
#  CryptoBot — Configuração
#  Copie este arquivo para .env e preencha suas credenciais
# ============================================================

# ── Exchange ─────────────────────────────────────────────────
EXCHANGE=binance          # binance | bybit | kucoin
API_KEY=SUA_API_KEY_AQUI
API_SECRET=SEU_API_SECRET_AQUI

# Para KuCoin também é necessário:
# API_PASSPHRASE=SUA_PASSPHRASE

# ── Par de trading ────────────────────────────────────────────
SYMBOL=BTC/USDT           # Par a ser operado
TIMEFRAME=15m             # 1m 5m 15m 1h 4h 1d

# ── Modo de operação ─────────────────────────────────────────
PAPER_TRADING=true        # true = simulação sem dinheiro real, false = ao vivo
PAPER_INITIAL_BALANCE=10000  # Saldo inicial para simulação (USDT)

# ── Parâmetros da estratégia ─────────────────────────────────
MA_FAST=7                 # Período da média móvel rápida
MA_SLOW=21                # Período da média móvel lenta
RSI_PERIOD=14             # Período do RSI
RSI_OVERSOLD=35           # RSI abaixo deste valor = sobrevendido (sinal de compra)
RSI_OVERBOUGHT=65         # RSI acima deste valor = sobrecomprado (sinal de venda)
BB_PERIOD=20              # Período das Bandas de Bollinger
BB_STD=2.0                # Desvios padrão das Bandas de Bollinger

# ── Gestão de risco ──────────────────────────────────────────
TRADE_SIZE_PCT=20         # % do saldo usado por trade (ex: 20 = 20%)
STOP_LOSS_PCT=3.0         # Stop loss em % (ex: 3.0 = -3%)
TAKE_PROFIT_PCT=6.0       # Take profit em % (ex: 6.0 = +6%)
MAX_OPEN_TRADES=1         # Máximo de posições abertas simultaneamente
MAX_DAILY_LOSS_PCT=10.0   # Limite de perda diária em % (bot para se atingir)

# ── Notificações Telegram (opcional) ────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/bot.log
# Opcional: segundo arquivo apenas JSON Lines (uma linha = um evento)
# BOT_JSON_LOG_FILE=logs/bot_events.jsonl
# BOT_METRICS_JSON=true   → grava métricas leves por ciclo em logs/bot_metrics.jsonl
